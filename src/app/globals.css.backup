@import "tailwindcss";

@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --bg: #0f0f0f;
  --surface: #1a1a1a;
  --border: #333;
  --text: #f1f1f1;
  --text-muted: #aaa;
  --primary: #646cff;
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  @apply min-h-screen leading-normal leading-normal;
  font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
  background: var(--bg);
  color: var(--text);
}

a {
  color: var(--primary);
  text-decoration: none;
}
a:hover {
  text-decoration: underline;
}

@layer components {
  /* ===== Buttons ===== */
  .btn {
    @apply rounded-lg border px-4 py-2 text-sm transition-colors;
    border-color: var(--border);
    background: var(--surface);
    color: var(--text);
    font-family: inherit;
  }
  .btn:hover { border-color: var(--primary); }
  .btn:disabled { @apply opacity-50 cursor-not-allowed; }

  .btn-primary {
    @apply btn bg-primary text-white hover:opacity-90;
  }

  /* ===== Art Field -- shared base for ArtInput & ArtTextarea ===== */
  .art-field-wrapper { @apply flex flex-col w-full; }
  .art-field-inner  { @apply relative flex w-full; }

  .art-field {
    @apply w-full min-w-[10rem] min-h-[2.25rem] text-sm rounded-md px-3 py-2;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    font-family: inherit;
  }

  .art-field-icon {
    @apply absolute left-2 top-1/2 -translate-y-1/2 text-[var(--text-muted)];
    pointer-events: none;
  }

  .art-field-clear {
    @apply absolute right-2 top-1/2 -translate-y-1/2 w-5 h-5 rounded-full;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--text-muted);
  }
  .art-field-clear:hover { color: var(--text); background: var(--border); }

  .art-field-helper { @apply text-[0.78rem] mt-1 leading-[1.3]; color: #e06464; }

  /* ===== Navbar ===== */
  .navbar { @apply flex items-center gap-4 px-6 py-2 border-b; border-color: var(--border); background: var(--surface); }
  .navbar-logo { @apply font-bold text-lg text-[var(--text)]; white-space:nowrap; }
  .navbar-search { @apply flex-1 max-w-[540px] mx-auto; }
  .navbar-upload { @apply text-[var(--text-muted)] flex items-center transition-colors; }
  .navbar-upload:hover { color: var(--text); }

  /* ===== ArtComboBox ===== */
  .art-combobox { @apply relative w-full; }
  .art-combobox-list {
    @apply absolute top-full left-0 right-0 mt-1 p-1 list-none rounded-md shadow-lg z-50 max-h-80 overflow-y-auto;
    background: var(--surface);
    border: 1px solid var(--border);
  }
  .art-combobox-option { @apply px-3 py-2 cursor-pointer text-sm transition-colors; }
  .art-combobox-option--active,
  .art-combobox-option:hover { background: var(--border); }
  .art-combobox-option--muted { @apply cursor-default; color: var(--text-muted); }

  /* ===== Video Page Layout ===== */
  .video-page { @apply flex gap-6; }
  .video-main { @apply flex-1 min-w-0; }
  .video-sidebar { @apply w-[400px] min-w-[340px]; }
  @media (max-width: 1024px) {
    .video-page { @apply flex-col; }
    .video-sidebar { @apply w-full min-w-0; }
  }

  /* ===== Video Grid ===== */
  .video-grid { @apply grid grid-cols-4 gap-6; }
  @media (max-width: 1024px) { .video-grid { @apply grid-cols-3; } }
  @media (max-width: 768px)  { .video-grid { @apply grid-cols-2; } }
  @media (max-width: 480px)  { .video-grid { @apply grid-cols-1; } }

  /* ===== Genre Badge ===== */
  .genre-badge {
    @apply text-xs px-2.5 py-0.5 rounded-full;
    background: var(--surface);
    color: var(--text-muted);
  }
}

/* focus ring for all Art fields */
input:focus, textarea:focus { outline: none; border-color: var(--primary); }

/* Shimmer skeleton used by loading placeholders */
@layer utilities {
  .shimmer {
    background: linear-gradient(90deg, #1a1a1a 25%, #333 50%, #1a1a1a 75%);
    background-size: 200% 100%;
    animation: shimmer 1.4s ease-in-out infinite;
    border-radius: 6px;
  }
}

@keyframes shimmer { 0% { background-position: 200% 0 } 100% { background-position: -200% 0 } }
