generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Genre {
  id   String @id @default(uuid()) @map("_id")
  name String @unique
}

model Video {
  id          String    @id @default(uuid()) @map("_id")
  title       String
  description String    @default("")
  thumbnail   String?
  videoUrl    String
  publishedAt DateTime  @default(now())
  ageRating   AgeRating @default(G_0)

  // Relations
  genreIds    String[]
  genres      Genre[]   @relation(fields: [genreIds], references: [id])
}

model Comment {
  id        String   @id @default(uuid()) @map("_id")
  text      String
  createdAt DateTime @default(now())

  // Relations
  videoId   String
  // No need in Prisma's relation, since no enrichment is needed. 
}

enum AgeRating {
  G_0
  G_12
  G_16
  G_18
}
